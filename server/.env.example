# Copia questo file in ".env" per lo sviluppo locale.
# Su Render, queste vanno impostate nella sezione "Environment" del web service,
# NON in un file .env caricato su GitHub (per sicurezza).

# Fornita automaticamente da Render quando colleghi un database Postgres al servizio.
# In locale, punta al tuo Postgres locale, es: postgres://user:pass@localhost:5432/nascondino
DATABASE_URL=

# Porta su cui gira il server. Render la imposta automaticamente, in locale usa 3001.
PORT=3001

# Codice segreto che sblocca il pannello admin. CAMBIALO prima di giocare!
ADMIN_UNLOCK_CODE=123456

# Credenziali Cloudinary (gratuite): registrati su https://cloudinary.com,
# nella dashboard trovi Cloud Name, API Key, API Secret già pronti.
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
